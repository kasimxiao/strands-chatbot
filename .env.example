# AWS 配置
AWS_REGION=us-east-1
AWS_PROFILE=default

# AgentCore 配置（在 Bedrock Console 创建 Agent 后获取）
AGENTCORE_AGENT_ID=your-agent-id
AGENTCORE_AGENT_ALIAS_ID=your-agent-alias-id

# Bedrock Knowledge Base 配置
# KB1: AWS EC2 相关文档
KNOWLEDGE_BASE_ID_AWS=KNWHSSCUVT
# KB2: 追觅扫地机器人文档
KNOWLEDGE_BASE_ID_DREAME=3KZDG0MTIV

# AgentCore Memory 配置
AGENTCORE_MEMORY_ENABLED=true
MEMORY_RETENTION_DAYS=30

# 模型配置
MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
MAX_TOKENS=4096
